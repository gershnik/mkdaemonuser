#! /usr/bin/env python3

"""Create a hidden macOS "daemon" user + group by calling the OpenDirectory C
API directly through ctypes (standard library only).
Requires root: writing to the local directory node is privileged.
"""

# pylint: disable=line-too-long, invalid-name

import argparse
import ctypes
import grp
import os
import pwd
import sys
from ctypes import POINTER, byref, c_bool, c_char_p, c_long, c_ulong, c_uint32, c_void_p


class DaemonUserError(Exception):
    """The request cannot be fulfilled for an explainable, expected reason.

    Distinct from bugs or OpenDirectory failures: these represent conditions the
    caller can understand and act on (e.g. not running as root, or no free ID in
    the allotted range). main() reports the message and exits non-zero without a
    traceback.
    """

# --------------------------------------------------------------------------- #
# Framework loading
# --------------------------------------------------------------------------- #

_CF_PATH = "/System/Library/Frameworks/CoreFoundation.framework/CoreFoundation"
_OD_PATH = "/System/Library/Frameworks/OpenDirectory.framework/OpenDirectory"
_CFOD_PATH = (
    "/System/Library/Frameworks/OpenDirectory.framework"
    "/Frameworks/CFOpenDirectory.framework/CFOpenDirectory"
)

cf = ctypes.CDLL(_CF_PATH, use_errno=True)
od = ctypes.CDLL(_OD_PATH, use_errno=True)
try:
    # The OD C functions/constants physically live in the CFOpenDirectory
    # sub-framework; the umbrella usually re-exports them, but bind explicitly.
    cfod = ctypes.CDLL(_CFOD_PATH, use_errno=True)
except OSError:
    cfod = od


def _fn(name, restype, argtypes):
    """Bind a C function from whichever OD handle exposes it."""
    for lib in (cfod, od):
        try:
            f = getattr(lib, name)
        except AttributeError:
            continue
        f.restype = restype
        f.argtypes = argtypes
        return f
    raise OSError(f"OpenDirectory symbol not found: {name}")


def _const_ptr(name: str) -> int:
    """Read an exported CFStringRef/pointer constant from the OD frameworks."""
    for lib in (cfod, od):
        try:
            value = c_void_p.in_dll(lib, name).value
        except ValueError:
            continue
        if value is None:
            raise OSError(f"OpenDirectory constant {name!r} resolved to NULL")
        return value
    raise OSError(f"OpenDirectory constant not found: {name}")


def _sym_addr(lib, name):
    """Address of an exported data symbol (e.g. a CF callbacks struct)."""
    return ctypes.addressof(ctypes.c_char.in_dll(lib, name))


# --------------------------------------------------------------------------- #
# CoreFoundation prototypes
# --------------------------------------------------------------------------- #

CFRelease = cf.CFRelease
CFRelease.restype = None
CFRelease.argtypes = [c_void_p]

CFStringCreateWithCString = cf.CFStringCreateWithCString
CFStringCreateWithCString.restype = c_void_p
CFStringCreateWithCString.argtypes = [c_void_p, c_char_p, c_uint32]

CFStringGetLength = cf.CFStringGetLength
CFStringGetLength.restype = c_long
CFStringGetLength.argtypes = [c_void_p]

CFStringGetMaximumSizeForEncoding = cf.CFStringGetMaximumSizeForEncoding
CFStringGetMaximumSizeForEncoding.restype = c_long
CFStringGetMaximumSizeForEncoding.argtypes = [c_long, c_uint32]

CFStringGetCString = cf.CFStringGetCString
CFStringGetCString.restype = c_bool
CFStringGetCString.argtypes = [c_void_p, c_char_p, c_long, c_uint32]

CFArrayCreate = cf.CFArrayCreate
CFArrayCreate.restype = c_void_p
CFArrayCreate.argtypes = [c_void_p, POINTER(c_void_p), c_long, c_void_p]

CFArrayGetCount = cf.CFArrayGetCount
CFArrayGetCount.restype = c_long
CFArrayGetCount.argtypes = [c_void_p]

CFArrayGetValueAtIndex = cf.CFArrayGetValueAtIndex
CFArrayGetValueAtIndex.restype = c_void_p
CFArrayGetValueAtIndex.argtypes = [c_void_p, c_long]

CFDictionaryCreate = cf.CFDictionaryCreate
CFDictionaryCreate.restype = c_void_p
CFDictionaryCreate.argtypes = [c_void_p, POINTER(c_void_p), POINTER(c_void_p), c_long, c_void_p, c_void_p]

CFGetTypeID = cf.CFGetTypeID
CFGetTypeID.restype = c_ulong
CFGetTypeID.argtypes = [c_void_p]

CFStringGetTypeID = cf.CFStringGetTypeID
CFStringGetTypeID.restype = c_ulong
CFStringGetTypeID.argtypes = []

CFErrorCopyDescription = cf.CFErrorCopyDescription
CFErrorCopyDescription.restype = c_void_p
CFErrorCopyDescription.argtypes = [c_void_p]

CFErrorGetCode = cf.CFErrorGetCode
CFErrorGetCode.restype = c_long
CFErrorGetCode.argtypes = [c_void_p]

CFErrorGetDomain = cf.CFErrorGetDomain
CFErrorGetDomain.restype = c_void_p
CFErrorGetDomain.argtypes = [c_void_p]

_ARRAY_CB = _sym_addr(cf, "kCFTypeArrayCallBacks")
_DICT_KEY_CB = _sym_addr(cf, "kCFTypeDictionaryKeyCallBacks")
_DICT_VAL_CB = _sym_addr(cf, "kCFTypeDictionaryValueCallBacks")

kCFStringEncodingUTF8 = 0x08000100

# --------------------------------------------------------------------------- #
# OpenDirectory prototypes
# --------------------------------------------------------------------------- #

ODNodeCreateWithNodeType = _fn(
    "ODNodeCreateWithNodeType", c_void_p, [c_void_p, c_void_p, c_long, POINTER(c_void_p)]
)
ODNodeCopyRecord = _fn(
    "ODNodeCopyRecord", c_void_p, [c_void_p, c_void_p, c_void_p, c_void_p, POINTER(c_void_p)]
)
ODNodeCreateRecord = _fn(
    "ODNodeCreateRecord", c_void_p, [c_void_p, c_void_p, c_void_p, c_void_p, POINTER(c_void_p)]
)
ODRecordSetValue = _fn(
    "ODRecordSetValue", c_bool, [c_void_p, c_void_p, c_void_p, POINTER(c_void_p)]
)
ODRecordCopyValues = _fn(
    "ODRecordCopyValues", c_void_p, [c_void_p, c_void_p, POINTER(c_void_p)]
)
ODRecordSynchronize = _fn(
    "ODRecordSynchronize", c_bool, [c_void_p, POINTER(c_void_p)]
)
ODQueryCreateWithNode = _fn(
    "ODQueryCreateWithNode",
    c_void_p,
    [c_void_p, c_void_p, c_void_p, c_void_p, c_long, c_void_p, c_void_p, c_long, POINTER(c_void_p)],
)
ODQueryCopyResults = _fn(
    "ODQueryCopyResults", c_void_p, [c_void_p, c_bool, POINTER(c_void_p)]
)

# Numeric enum constants (compile-time in the headers, so hardcoded here).
kODNodeTypeLocalNodes = 0x2200
kODMatchEqualTo = 0x2001
kODErrorRecordAlreadyExists = 4102  # verified against <OpenDirectory/OpenDirectory.h>
CFINDEX_MAX = 0x7FFFFFFFFFFFFFFF

# CFStringRef / pointer constants (resolved from the framework symbol table).
kODRecordTypeUsers = _const_ptr("kODRecordTypeUsers")
kODRecordTypeGroups = _const_ptr("kODRecordTypeGroups")
kODAttributeTypeUniqueID = _const_ptr("kODAttributeTypeUniqueID")
kODAttributeTypePrimaryGroupID = _const_ptr("kODAttributeTypePrimaryGroupID")
kODAttributeTypeUserShell = _const_ptr("kODAttributeTypeUserShell")
kODAttributeTypePassword = _const_ptr("kODAttributeTypePassword")
kODAttributeTypeNFSHomeDirectory = _const_ptr("kODAttributeTypeNFSHomeDirectory")
kODAttributeTypeFullName = _const_ptr("kODAttributeTypeFullName")
kODAttributeTypeAllAttributes = _const_ptr("kODAttributeTypeAllAttributes")
_kODErrorDomainFramework = _const_ptr("kODErrorDomainFramework")

# The default session is NULL: passing NULL to ODNodeCreateWithNodeType selects
# it. So there's nothing to look up (and no error to swallow) here.
kODSessionDefault = None

# Defaults.
DEFAULT_SHELL = "/usr/bin/false"
DEFAULT_PASSWORD = "*"  # disables password login
ID_RANGE = (501, 699)


# --------------------------------------------------------------------------- #
# CoreFoundation helpers
# --------------------------------------------------------------------------- #

def _cfstr(s: str) -> int:
    """Create an owned CFString from a Python str (caller must CFRelease)."""
    ref = CFStringCreateWithCString(None, s.encode("utf-8"), kCFStringEncodingUTF8)
    if not ref:
        raise RuntimeError("CFStringCreateWithCString failed")
    return ref


def _pystr(cfstring: int | None) -> str:
    if not cfstring:
        return ""
    length = CFStringGetLength(cfstring)
    maxsize = CFStringGetMaximumSizeForEncoding(length, kCFStringEncodingUTF8) + 1
    buf = ctypes.create_string_buffer(maxsize)
    if not CFStringGetCString(cfstring, buf, maxsize, kCFStringEncodingUTF8):
        raise RuntimeError("CFStringGetCString failed")
    return buf.value.decode("utf-8")


def _cfarray(item_ptrs: list[int]) -> int:
    """Create an owned CFArray of CF objects (kCFType retain/release callbacks)."""
    n = len(item_ptrs)
    if n == 0:
        ref = CFArrayCreate(None, None, 0, _ARRAY_CB)
    else:
        values = (c_void_p * n)(*(c_void_p(p) for p in item_ptrs))
        ref = CFArrayCreate(None, values, n, _ARRAY_CB)
    if not ref:
        raise RuntimeError("CFArrayCreate failed")
    return ref


def _cfdict(pairs: list[tuple[int, int]]) -> int:
    n = len(pairs)
    keys = (c_void_p * n)(*(c_void_p(k) for k, _ in pairs))
    vals = (c_void_p * n)(*(c_void_p(v) for _, v in pairs))
    ref = CFDictionaryCreate(None, keys, vals, n, _DICT_KEY_CB, _DICT_VAL_CB)
    if not ref:
        raise RuntimeError("CFDictionaryCreate failed")
    return ref


def _new_err() -> ctypes.c_void_p:
    return c_void_p()


def _release_error(err: ctypes.c_void_p) -> None:
    """Release a CFErrorRef out-param if one was produced, discarding it."""
    handle = err.value
    if handle:
        CFRelease(handle)


def _drain_error(err: ctypes.c_void_p) -> tuple[int | None, str]:
    """Consume a CFErrorRef out-param, returning (code, domain) and releasing it."""
    handle = err.value
    if not handle:
        return None, ""
    code = CFErrorGetCode(handle)
    domain = _pystr(CFErrorGetDomain(handle))  # domain is borrowed
    CFRelease(handle)
    return code, domain


def _raise_cf_error(err: ctypes.c_void_p):
    handle = err.value
    if not handle:
        raise RuntimeError("OpenDirectory call failed with no error object")
    desc = CFErrorCopyDescription(handle)  # owned
    try:
        msg = _pystr(desc)
    finally:
        if desc:
            CFRelease(desc)
    code = CFErrorGetCode(handle)
    CFRelease(handle)
    raise RuntimeError(f"OpenDirectory error {code}: {msg}")


# --------------------------------------------------------------------------- #
# OpenDirectory record helpers
# --------------------------------------------------------------------------- #

def _set_attr_strings(record: int, attribute: int, values: list[str]) -> None:
    cfvals = [_cfstr(v) for v in values]
    try:
        arr = _cfarray(cfvals)
        try:
            err = _new_err()
            if not ODRecordSetValue(record, attribute, arr, byref(err)):
                _raise_cf_error(err)
        finally:
            CFRelease(arr)
    finally:
        for v in cfvals:
            CFRelease(v)


def _synchronize(record: int) -> None:
    err = _new_err()
    if not ODRecordSynchronize(record, byref(err)):
        _raise_cf_error(err)


def _get_string_attribute(record: int, attribute: int) -> str | None:
    """Read a single-valued string attribute from a record.

    Returns the string if the attribute holds exactly one string value, the
    empty string if that one value is null, and None if the attribute is absent,
    multi-valued, or not a string.
    """
    err = _new_err()
    val_array = ODRecordCopyValues(record, attribute, byref(err))
    if not val_array:
        _release_error(err)
        return None
    try:
        if CFArrayGetCount(val_array) != 1:
            return None
        value = CFArrayGetValueAtIndex(val_array, 0)  # borrowed
        if not value:
            return ""
        if CFGetTypeID(value) != CFStringGetTypeID():
            return None
        return _pystr(value)
    finally:
        CFRelease(val_array)


def _get_available_id(node: int, record_type: int, attribute: int, id_range: tuple[int, int]) -> int:
    lo, hi = id_range
    assert hi >= lo
    empty_attrs = _cfarray([])  # request no attributes back; we only count matches
    try:
        for id_value in range(lo, hi + 1):
            str_id = _cfstr(str(id_value))
            try:
                err = _new_err()
                query = ODQueryCreateWithNode(
                    None, node, record_type, attribute, kODMatchEqualTo,
                    str_id, empty_attrs, CFINDEX_MAX, byref(err),
                )
                if not query:
                    _raise_cf_error(err)
                try:
                    err = _new_err()
                    results = ODQueryCopyResults(query, False, byref(err))
                    if not results:
                        _raise_cf_error(err)
                    try:
                        if CFArrayGetCount(results) == 0:
                            return id_value
                    finally:
                        CFRelease(results)
                finally:
                    CFRelease(query)
            finally:
                CFRelease(str_id)
    finally:
        CFRelease(empty_attrs)
    raise DaemonUserError(f"Unable to find available {_pystr(attribute)} ID")


def _create_record_with_unique_id(
    node: int, name_cf: int, record_type: int, unique_id_attribute: int, id_range: tuple[int, int]
) -> tuple[int, int]:
    """Return (record, id) for `name_cf`, creating the record if needed.

    If a record with this name already exists, its identifier attribute is
    reused; if the record exists but lacks that attribute, a free id is assigned
    to it. Otherwise a new record is created with the next free id in `id_range`.
    The returned ODRecordRef is owned and must be released by the caller.
    """
    attr_to_fetch = _cfarray([kODAttributeTypeAllAttributes])
    try:
        while True:
            err = _new_err()
            record = ODNodeCopyRecord(node, record_type, name_cf, attr_to_fetch, byref(err))

            if not record:
                _release_error(err)  # discard the "not found" error; proceed to create
                id_value = _get_available_id(node, record_type, unique_id_attribute, id_range)
                str_id = _cfstr(str(id_value))
                arr = _cfarray([str_id])
                attrs = _cfdict([(unique_id_attribute, arr)])
                try:
                    err = _new_err()
                    record = ODNodeCreateRecord(node, record_type, name_cf, attrs, byref(err))
                    if not record:
                        code, domain = _drain_error(err)
                        if domain == _pystr(_kODErrorDomainFramework) and code == kODErrorRecordAlreadyExists:
                            continue  # race: someone created it — retry the read
                        raise RuntimeError(f"ODNodeCreateRecord failed (error {code})")
                finally:
                    CFRelease(attrs)
                    CFRelease(arr)
                    CFRelease(str_id)
                return record, id_value

            # Record already exists.
            maybe_id = _get_string_attribute(record, unique_id_attribute)
            if maybe_id is not None:
                try:
                    return record, int(maybe_id)
                except ValueError as exc:
                    CFRelease(record)
                    raise RuntimeError("Invalid identifier attribute value") from exc

            id_value = _get_available_id(node, record_type, unique_id_attribute, id_range)
            _set_attr_strings(record, unique_id_attribute, [str(id_value)])
            _synchronize(record)
            return record, id_value
    finally:
        CFRelease(attr_to_fetch)


# --------------------------------------------------------------------------- #
# Public entry point
# --------------------------------------------------------------------------- #

def _existing_kind(name: str) -> str | None:
    """Return 'user'/'group' if a record with this name already exists, else None.

    Uses getpwnam/getgrnam, so it sees every directory source the system is
    configured with (local node plus any LDAP/AD), not just the local node.
    """
    try:
        pwd.getpwnam(name)
        return "user"
    except KeyError:
        pass
    try:
        grp.getgrnam(name)
        return "group"
    except KeyError:
        pass
    return None


def create_daemon_user(
    name: str,
    full_name: str,
    home_directory: str,
    shell: str = DEFAULT_SHELL,
    password: str = DEFAULT_PASSWORD,
) -> tuple[int, int]:
    """Create the hidden daemon group + user and return (uid, gid).

    `full_name` is applied to both the user and the group. `home_directory` and
    `full_name` are mandatory; `shell` and `password` fall back to a disabled
    login shell and a disabled password.

    The caller is responsible for ensuring the process is root and that no user
    or group already claims `name` (see main()); this function performs the OD
    writes and will surface a lower-level error if those preconditions fail.
    """
    err = _new_err()
    node = ODNodeCreateWithNodeType(None, kODSessionDefault, kODNodeTypeLocalNodes, byref(err))
    if not node:
        _raise_cf_error(err)

    try:
        cfname = _cfstr(name)
        try:
            group, gid = _create_record_with_unique_id(
                node, cfname, kODRecordTypeGroups, kODAttributeTypePrimaryGroupID, ID_RANGE
            )
            try:
                user, uid = _create_record_with_unique_id(
                    node, cfname, kODRecordTypeUsers, kODAttributeTypeUniqueID, ID_RANGE
                )
                try:
                    is_hidden = _cfstr("dsAttrTypeNative:IsHidden")
                    try:
                        _set_attr_strings(user, kODAttributeTypePrimaryGroupID, [str(gid)])
                        _set_attr_strings(user, kODAttributeTypeUserShell, [shell])
                        _set_attr_strings(user, kODAttributeTypePassword, [password])
                        _set_attr_strings(user, kODAttributeTypeNFSHomeDirectory, [home_directory])
                        _set_attr_strings(user, is_hidden, ["1"])
                        _set_attr_strings(user, kODAttributeTypeFullName, [full_name])
                        _synchronize(user)

                        _set_attr_strings(group, is_hidden, ["1"])
                        _set_attr_strings(group, kODAttributeTypeFullName, [full_name])
                        _synchronize(group)
                    finally:
                        CFRelease(is_hidden)
                    return uid, gid
                finally:
                    CFRelease(user)
            finally:
                CFRelease(group)
        finally:
            CFRelease(cfname)
    finally:
        CFRelease(node)


def main(argv: list[str] | None = None) -> int:
    """main entry point"""
    parser = argparse.ArgumentParser(
        description="Create a hidden macOS daemon user and a matching group.",
    )
    parser.add_argument("login", help="record name for both the user and the group")
    parser.add_argument(
        "-c", "--comment", dest="full_name", required=True,
        help="full name (GECOS); applied to both the user and the group",
    )
    parser.add_argument(
        "-d", "--home-dir", dest="home_directory", required=True,
        help="home directory (NFSHomeDirectory)",
    )
    parser.add_argument(
        "-s", "--shell", default=DEFAULT_SHELL,
        help="login shell (default: %(default)s)",
    )
    parser.add_argument(
        "-p", "--password", default=DEFAULT_PASSWORD,
        help='password attribute (default: %(default)r, which disables login)',
    )
    args = parser.parse_args(argv)

    try:
        if os.geteuid() != 0:
            raise DaemonUserError("must be run as root (writes to the local directory node)")
        existing = _existing_kind(args.login)
        if existing:
            raise DaemonUserError(f"a {existing} named {args.login!r} already exists")
        uid, gid = create_daemon_user(
            args.login,
            full_name=args.full_name,
            home_directory=args.home_directory,
            shell=args.shell,
            password=args.password,
        )
    except DaemonUserError as exc:
        print(f"{parser.prog}: error: {exc}", file=sys.stderr)
        return 1
    print(f"uid={uid} gid={gid}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
